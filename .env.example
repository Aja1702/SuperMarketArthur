# ==========================================
# Variables de Entorno - SuperMarket Arthur
# ==========================================
# Copia este archivo a .env y completa los valores

# --- Base de Datos ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=supermarket_arthur
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# --- Aplicación ---
APP_NAME="SuperMarket Arthur"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/SuperMarketArthur

# --- Seguridad ---
APP_KEY=
SESSION_LIFETIME=120
REMEMBER_ME_LIFETIME=604800

# --- Email ---
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@supermarketarthur.local
MAIL_FROM_NAME="SuperMarket Arthur"

# --- Cache ---
CACHE_DRIVER=file
CACHE_LIFETIME=3600

# --- Logging ---
LOG_CHANNEL=single
LOG_LEVEL=debug

# --- APIs Externas (Opcional) ---
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
