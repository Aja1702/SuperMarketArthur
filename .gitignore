# ==========================================
# Ignorar Archivos y Carpetas
# ==========================================

# --- Dependencias ---
vendor/
node_modules/
composer.lock
package-lock.json
yarn.lock

# --- Variables de Entorno ---
.env
.env.local
.env.*.local
.env.backup

# --- Storage (Cache y Logs) ---
storage/cache/*
storage/logs/*
!storage/cache/.gitkeep
!storage/logs/.gitkeep

# --- Archivos Temporales ---
*.log
*.tmp
*.bak
*.swp
*.swo
*~
.tmp/

# --- IDE y Editores ---
.vscode/
.idea/
.sublime-project
.sublime-workspace
*.code-workspace
.netbeans/

# --- Sistema Operativo ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# --- PHP Unit ---
.phpunit.result.cache
phpunit.xml.dist

# --- Build y Dist ---
dist/
build/
out/
.cache/

# --- DevOps ---
docker-compose.override.yml
.docker/

# --- Backups ---
*.backup
*.sql.gz
db_backups/

# --- Archivos Específicos ---
.DS_Store
.env.production
config/database.local.php

# --- Archivos de Tests ---
tests/**/*.log
tests/**/coverage/

# --- NPM/Node (si se usa) ---
node_modules/
.npm
.eslintcache

# --- Carpetas de Compilación ---
/dist
/build
/coverage
/out

# --- Archivos de Bloqueo ---
.lock
*.lock~

